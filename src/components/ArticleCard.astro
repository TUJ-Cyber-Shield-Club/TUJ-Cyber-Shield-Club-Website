---
import { Image } from 'astro:assets';
import { formatDate, readingTime, withBase, type Article } from '../utils/articles';

interface Props {
  article: Article;
  /** Heading level for the card title, so lists keep a sane outline. */
  headingLevel?: 'h2' | 'h3';
  eager?: boolean;
}

const { article, headingLevel: Heading = 'h3', eager = false } = Astro.props;
const { title, description, pubDate, authors, coverImage, coverAlt, draft } = article.data;
const url = withBase(`/articles/${article.id}/`);
const minutes = readingTime(article.body);
---

<li class="card" data-issue={article.data.issue}>
  {
    coverImage && (
      <div class="card-cover">
        <Image
          src={coverImage}
          alt={coverAlt ?? ''}
          width="640"
          height="336"
          loading={eager ? 'eager' : 'lazy'}
        />
      </div>
    )
  }
  <Heading>
    <a href={url}>{title}{draft && ' (draft preview)'}</a>
  </Heading>
  <p>{description}</p>
  <p class="meta">
    <b>{authors.join(', ')}</b> ·{' '}
    <time datetime={pubDate.toISOString().slice(0, 10)}>{formatDate(pubDate)}</time> · {minutes} min
    read
  </p>
</li>
