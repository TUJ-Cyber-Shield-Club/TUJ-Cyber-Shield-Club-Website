---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import logo from '../assets/logo.png';
import developer from '../assets/team/carl-masters.png';
import { withBase } from '../utils/articles';

const joinForm =
  'https://docs.google.com/forms/d/e/1FAIpQLSf8e37fWWAWD6axVy3mzr_sbEWz8ce-pZ0NZT-cZfEaTNVqkA/viewform?usp=header';
---

<Base
  title="About the club · Cyber Shield"
  description="Cyber Shield is TUJ's digital-safety club: students translating real security research into plain-language advice anyone can use."
>
  <div class="about">
    <header class="masthead">
      <p class="flank flank--center">About the club</p>
      <h1>Security research, translated for everyone.</h1>
    </header>

    <div class="logo-plate">
      <Image
        src={logo}
        alt="The full TUJ Cyber Shield Club crest: an owl holding a padlock on a teal shield above the club wordmark"
        width="360"
        loading="eager"
      />
    </div>

    <div class="prose">
      <p>
        Cyber Shield aims to cultivate a community of students passionate about digital safety and
        cybersecurity awareness. We provide an inclusive space for researching modern threats,
        analyzing real-world vulnerabilities, and translating complex security topics into
        accessible, actionable advice. Through collaborative research, guest speakers, and our
        monthly publications, members help everyday students harden their digital lives without
        needing a technical background.
      </p>
      <p>
        Our activities welcome all skill levels and backgrounds, though we are always excited to
        connect with students who have a passion for deep technical research or a talent for
        writing and communication, fostering a culture of curiosity, critical thinking, and
        community-driven protection.
      </p>

      <h2>What members actually do</h2>
      <ul>
        <li><strong>Research:</strong> track current scams, breaches, and threats affecting students.</li>
        <li><strong>Write:</strong> turn that research into short, jargon-free monthly articles.</li>
        <li><strong>Edit:</strong> every article is peer-reviewed for accuracy and readability.</li>
        <li><strong>Learn:</strong> guest speakers and workshops, open to every skill level.</li>
      </ul>

      <h2>How to join</h2>
      <p>
        We'd love to have you. No application, no experience needed. Curiosity is the only
        requirement. Follow us on Instagram at{' '}
        <a href="https://www.instagram.com/tuj_cyber_shield_club/" target="_blank" rel="noopener"
          >@tuj_cyber_shield_club</a
        >{' '}
        for updates, and when you're ready to sign up, use the form below.
      </p>
      <p class="join-cta">
        <a class="button" href={joinForm} target="_blank" rel="noopener">Join here</a>
      </p>

      <p>
        Prefer to start by reading? <a href={withBase('/articles/')}>Browse our articles</a>,{' '}
        <a href={withBase('/team/')}>meet the team</a>, or subscribe to the{' '}
        <a href={withBase('/rss.xml')}>RSS feed</a>.
      </p>
    </div>

    <section class="developer" aria-labelledby="developer-heading">
      <p class="flank">Behind the site</p>
      <h2 id="developer-heading">The developer</h2>
      <div class="developer-card">
        <Image
          class="dev-avatar"
          src={developer}
          alt="Photo of Carl Masters"
          width="220"
          height="220"
          fit="cover"
          loading="lazy"
        />
        <div class="prose dev-bio">
          <!-- EDIT ME, Carl: personalize this bio and swap in a real photo at
               src/assets/team/carl-masters.png -->
          <p>
            This site was designed and built by <strong
              ><a href="https://carlmasters.com" target="_blank" rel="noopener">Carl Masters</a
              ></strong
            >, a cybersecurity student at TUJ and founder of the Cyber Shield Club. The site was
            built to be fast,
            accessible, and simple enough that any club member can publish an article without
            writing a line of code.
          </p>
          <p>
            If you have any questions about the website or would like to report any issues, please
            reach out at{' '}
            <a href="mailto:carl.masters.dev@protonmail.com">carl.masters.dev@protonmail.com</a>.
          </p>
        </div>
      </div>
    </section>
  </div>
</Base>

<style>
  .about {
    max-width: 46rem;
    margin-inline: auto;
  }

  .masthead {
    text-align: center;
  }

  .masthead h1 {
    font-size: clamp(1.9rem, 5vw, 2.8rem);
    margin-top: 1rem;
  }

  /* The full crest keeps its white wordmark readable via an ink plate. */
  .logo-plate {
    display: grid;
    place-items: center;
    margin-block: 2.25rem;
    padding: 2rem 1rem;
    background: var(--ink);
    border-radius: 12px;
    border: 1px solid var(--line);
  }

  .prose {
    margin-inline: auto;
  }

  .join-cta {
    margin-block: 1.25rem;
  }

  .developer {
    max-width: 46rem;
    margin: clamp(3rem, 8vw, 4.5rem) auto 0;
    padding-top: clamp(2rem, 5vw, 3rem);
    border-top: 1px solid var(--line);
  }

  .developer h2 {
    font-size: 1.6rem;
    margin-top: 0.5rem;
  }

  .developer-card {
    display: flex;
    gap: 1.5rem;
    margin-top: 1.5rem;
    align-items: flex-start;
  }

  .dev-avatar {
    flex: 0 0 auto;
    width: 6rem;
    height: 6rem;
    border-radius: 50%;
    border: 1px solid var(--line);
    background: var(--bg-inset);
    object-fit: cover;
  }

  .dev-bio {
    margin: 0;
    font-size: 1.05rem;
  }

  .dev-bio > * + * {
    margin-top: 1em;
  }

  @media (max-width: 34rem) {
    .developer-card {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
